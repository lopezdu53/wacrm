# Keep the build context small and never ship local secrets or artifacts.
node_modules
.next
out
build
coverage

# Local env files — configuration is injected at runtime, never baked in.
.env
.env.*
!.env.local.example
!.env.example

# Git / CI / editor noise
.git
.github
.gitignore
.editorconfig
.prettierignore
.prettierrc
.vercel

# Docs & meta not needed in the image
*.md
!next.config.ts

# OS / debug
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
